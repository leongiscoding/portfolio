# Portfolio environment template.
#
# Copy this file to `.env.local` at the repo root (NOT inside a worktree).
# `.env.local` is gitignored; never commit real secrets.
#
#   cp .env.example .env.local
#
# Variables prefixed `NEXT_PUBLIC_` are exposed to the browser.
# Variables without that prefix are server-only — keep them out of client code.

# --- Contact form (Web3Forms) ---
# Key from https://web3forms.com — safe to expose (public form key).
NEXT_PUBLIC_WEB3FORMS_KEY=

# --- Supabase CMS (populated when Phase 1 lands) ---
# Dashboard → Project Settings → API.
# Use the DEV project's keys locally. Production keys belong in Vercel env.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Admin auth (populated when Phase 3 lands) ---
# Single-user login for /admin. Plaintext password is acceptable because
# `.env.local` is gitignored and Vercel encrypts env vars at rest.
# Change ADMIN_PASSWORD here + restart the server to rotate.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# AUTH_SECRET=    # random 32+ byte string for JWT signing; generate with: openssl rand -base64 32
